# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/auraproject

# ─── Session / JWT ────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_session_secret
JWT_SECRET=change_me_jwt_secret

# ─── Password Reset Token (short-lived, separate secret recommended) ──────────
# Used to sign the one-time reset token issued after OTP verification.
# Expires in 5 minutes. If omitted, falls back to JWT_SECRET.
RESET_TOKEN_SECRET=change_me_reset_token_secret

# ─── Email (OTP sending via Nodemailer / Gmail) ───────────────────────────────
EMAIL_USER=your-gmail@gmail.com
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
EMAIL_PASS=your-gmail-app-password

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── OAuth – Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth – Naver ────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── Steam ────────────────────────────────────────────────────────────────────
STEAM_WEB_API_KEY=
