diff --git a/deploy.sh b/deploy.sh
new file mode 100644
index 0000000..3e09aed
--- /dev/null
+++ b/deploy.sh
@@ -0,0 +1,31 @@
+#!/bin/bash
+set -e
+
+echo "======================================"
+echo "  AuraProject Deployment"
+echo "======================================"
+
+# 사용하지 않는 이미지/컨테이너 정리 (디스크 공간 확보)
+echo "[1/4] 불필요한 Docker 리소스 정리..."
+docker image prune -f --filter "until=24h" || true
+
+# 이미지 빌드 (변경된 서비스만 재빌드)
+echo "[2/4] Docker 이미지 빌드..."
+docker compose build --no-cache
+
+# 컨테이너 재시작 (무중단 순서: backend → frontend → nginx)
+echo "[3/4] 컨테이너 재시작..."
+docker compose up -d --remove-orphans
+
+# 헬스체크 대기
+echo "[4/4] 서비스 상태 확인..."
+sleep 15
+if docker compose ps | grep -q "unhealthy\|Exit"; then
+    echo "❌ 일부 컨테이너가 비정상입니다:"
+    docker compose ps
+    exit 1
+fi
+
+echo ""
+echo "✅ 배포 완료!"
+docker compose ps
